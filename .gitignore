# --- Default: ignore everything ---
*

# --- Explicitly track your configs ---
!.gitignore
!starship.toml

!themes/
!themes/**

# --- themes: ignore generated tool configs (regenerate with themes/scripts/gen-*.sh) ---
themes/*/*-colors.conf
themes/*/*-colors.css
themes/*/*-colors.rasi

!rofi/
!rofi/**

!btop/
!btop/**

!dunst/
!dunst/**

# --- dunst: ignore generated dunstrc (regenerate with themes/scripts/gen-dunst.sh) ---
dunst/dunstrc

!git/
!git/**

!hypr/
!hypr/**

!kitty/
!kitty/**

!lazygit/
!lazygit/**

!waybar/
!waybar/**

!nvim/
!nvim/**

!tmux/
!tmux/**

!scripts/
!scripts/**

!install.sh

# --- Hyprland runtime/state files ---
hypr/hyprland.conf.d/
hypr/*.log

# --- btop: ignore state and proc cache ---
btop/btop.log
btop/themes/

# --- kitty: ignore session files ---
kitty/kitty.session

# --- tmux: ignore plugin files ---
tmux/plugins/

# --- Common junk to suppress ---
*.swp
*.swo
*~
.DS_Store
