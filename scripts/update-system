#!/usr/bin/env bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

header() { echo -e "\n${BLUE}${BOLD}▶ $1${RESET}"; }
ok()     { echo -e "${GREEN}✔ $1${RESET}"; }
warn()   { echo -e "${YELLOW}⚠ $1${RESET}"; }
fail()   { echo -e "${RED}✘ $1${RESET}"; }

echo -e "${CYAN}${BOLD}"
echo "  ╔══════════════════════════════╗"
echo "  ║      System Update           ║"
echo "  ╚══════════════════════════════╝"
echo -e "${RESET}"

header "Updating pacman packages"
if sudo pacman -Syu --noconfirm; then
    ok "pacman done"
else
    fail "pacman failed"
fi

header "Updating AUR packages"
if command -v paru &>/dev/null; then
    paru -Syu --noconfirm && ok "paru done" || fail "paru failed"
elif command -v yay &>/dev/null; then
    yay -Syu --noconfirm && ok "yay done" || fail "yay failed"
else
    warn "No AUR helper found — skipping"
fi

header "Updating Flatpak packages"
if command -v flatpak &>/dev/null; then
    flatpak update -y && ok "flatpak done" || fail "flatpak failed"
else
    warn "Flatpak not installed — skipping"
fi

header "Reloading firewall"
if sudo nft list ruleset 2>/dev/null | grep -q 'table'; then
    if sudo nft -c -f /etc/nftables.conf 2>/dev/null; then
        sudo systemctl restart nftables && ok "nftables reloaded" || fail "nftables reload failed"
    else
        fail "nftables config has errors — not reloading"
    fi
elif systemctl is-enabled --quiet nftables 2>/dev/null; then
    sudo systemctl start nftables && ok "nftables started" || fail "nftables failed to start"
else
    warn "nftables not enabled — run: sudo systemctl enable --now nftables"
fi

header "Cleaning up"
orphans=$(pacman -Qdtq 2>/dev/null)
if [[ -n "$orphans" ]]; then
    echo "$orphans" | sudo pacman -Rns - --noconfirm && ok "orphans removed" || fail "failed to remove orphans"
else
    ok "no orphans"
fi
if command -v paccache &>/dev/null; then
    sudo paccache -r && ok "cache cleaned (kept last 3 versions)"
else
    warn "paccache not found — install pacman-contrib for better cache cleaning"
fi

echo -e "\n${GREEN}${BOLD}  ✔ System fully updated!${RESET}\n"
